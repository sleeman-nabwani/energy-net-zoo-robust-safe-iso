{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SafeISO Evaluation Suite",
  "type": "object",
  "required": ["name", "mode", "algo", "horizon", "episodes", "cost_limit", "device", "scenarios"],
  "properties": {
    "name": {"type": "string"},
    "mode": {"type": "string", "enum": ["ISOOnly", "CMDP"]},
    "algo": {"type": "string"},
    "horizon": {"type": "integer", "minimum": 1},
    "episodes": {"type": "integer", "minimum": 1},
    "base_seeds": {
      "type": "array",
      "items": {"type": "integer"},
      "minItems": 1,
      "uniqueItems": true
    },
    "cost_limit": {"type": "number", "minimum": 0},
    "device": {"type": "string"},
    "output_dir": {"type": "string"},
    "metadata": {
      "type": "object",
      "properties": {
        "git_sha": {"type": "string"},
        "pkg_versions": {"type": "object"},
        "vf_config": {"type": "object"},
        "cost_config": {"type": "object"}
      },
      "additionalProperties": true
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "preset", "pcs"],
        "properties": {
          "name": {"type": "string"},
          "preset": {"type": "string"},
          "pcs": {"type": "string"},
          "episodes": {"type": "integer", "minimum": 1},
          "pricing_policy": {"type": "string"},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}




